<Window x:Class="Sah.Claude.Usage.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sah.Claude.Usage.Wpf" Height="450" Width="800"
        Background="{DynamicResource AppBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource AppBorder}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="4">
                <Button x:Name="RefreshButton"
                        AutomationProperties.AutomationId="RefreshButton"
                        Click="OnRefreshClick"
                        ToolTip="Refresh"
                        Width="32" Height="32" Margin="0,0,4,0"
                        Padding="0"
                        FontFamily="Segoe MDL2 Assets" FontSize="16"
                        Content="&#xE72C;"
                        Foreground="{DynamicResource AppForeground}"/>
                <Button x:Name="SettingsButton"
                        AutomationProperties.AutomationId="SettingsButton"
                        Click="OnSettingsClick"
                        ToolTip="Settings"
                        Width="32" Height="32"
                        Padding="0"
                        FontFamily="Segoe MDL2 Assets" FontSize="16"
                        Content="&#xE713;"
                        Foreground="{DynamicResource AppForeground}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsList" HorizontalContentAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
