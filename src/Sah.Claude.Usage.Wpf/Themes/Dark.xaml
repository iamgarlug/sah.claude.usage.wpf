<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackground"        Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AppForeground"        Color="#D4D4D4"/>
    <SolidColorBrush x:Key="AppBorder"            Color="#404040"/>
    <SolidColorBrush x:Key="AppButtonBackground"  Color="#2D2D2D"/>
    <SolidColorBrush x:Key="AppButtonHover"       Color="#3D3D3D"/>
    <SolidColorBrush x:Key="AppButtonPressed"     Color="#505050"/>
</ResourceDictionary>
